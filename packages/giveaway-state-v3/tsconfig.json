{
  "extends": "@dougley/tsconfig/workers",
  "compilerOptions": {
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "allowJs": true,
    "skipLibCheck": true,
    "types": [
      "@dougley/types/workers-env",
      "@cloudflare/workers-types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "dist",
    "prisma"
  ]
}