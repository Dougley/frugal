# Vite client-side environment variables (VITE_* prefix required)
# Copy this to .env and fill in values for local development

# Environment identifier
VITE_ENVIRONMENT=development

# Site URL (used for OG images and OAuth redirects)
VITE_SITE_URL=http://localhost:3000

# Discord Application ID (for invite links)
VITE_DISCORD_APP_ID=

# Sentry DSN for error reporting (optional)
# VITE_SENTRY_DSN=

# Release version (auto-set in CI from git SHA)
# VITE_RELEASE=
