{
  "name": "@dougley/frugal-discord-new",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.mjs",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "wrangler dev --persist-to='../../.mf' src/index.ts",
    "deploy": "wrangler deploy --minify src/index.ts",
    "db:migrate:dev": "wrangler d1 migrations apply frugal --local --persist-to='../../.mf'",
    "db:migrate": "wrangler d1 migrations apply frugal",
    "register": "tsx scripts/register-commands.mjs",
    "register:dev": "tsx scripts/register-commands.mjs --env development",
    "typecheck": "wrangler types && tsc --noEmit",
    "i18n:sync": "node scripts/kv-i18n-sync.mjs",
    "i18n:sync:dev": "node scripts/kv-i18n-sync.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dougley/frugal.git",
    "directory": "apps/discord"
  },
  "dependencies": {
    "@dougley/frugal-drizzle": "workspace:^",
    "@dougley/frugal-i18n": "workspace:^",
    "@dougley/frugal-savestate": "workspace:^",
    "@dougley/frugal-subscriptions": "workspace:^",
    "@dougley/frugal-utils": "workspace:^",
    "@sentry/cloudflare": "^10.32.1",
    "slash-create": "^6.7.1"
  },
  "devDependencies": {
    "@dougley/tsconfig": "workspace:^",
    "@dougley/types": "workspace:^",
    "@types/node": "^25.0.3",
    "better-sqlite3": "^12.5.0",
    "discord-api-types": "catalog:",
    "dotenv": "^17.2.3",
    "slash-up": "^1.4.2",
    "tsx": "^4.21.0",
    "wrangler": "catalog:"
  }
}
