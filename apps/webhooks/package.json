{
  "name": "@dougley/frugal-webhooks",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.mjs",
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "dev": "wrangler dev --persist-to='../../.mf' src/index.ts",
    "deploy": "wrangler deploy --minify src/index.ts",
    "lint": "eslint --ext .ts .",
    "lint:fix": "eslint --ext .ts . --fix",
    "format": "prettier -w ./src",
    "typecheck": "wrangler types && tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dougley/frugal.git",
    "directory": "apps/webhooks"
  },
  "dependencies": {
    "@dougley/frugal-drizzle": "workspace:^",
    "@dougley/frugal-subscriptions": "workspace:^",
    "@dougley/frugal-utils": "workspace:^",
    "@sentry/cloudflare": "^10.15.0",
    "hono": "^4.9.9"
  },
  "devDependencies": {
    "@dougley/tsconfig": "workspace:^",
    "@dougley/types": "workspace:^",
    "@types/node": "^24.5.2",
    "better-sqlite3": "^12.4.1",
    "discord-api-types": "catalog:",
    "dotenv": "^17.2.2",
    "vitest": "^3.2.4",
    "wrangler": "catalog:"
  }
}