{
  "name": "@dougley/frugal",
  "packageManager": "pnpm@10.17.1",
  "version": "0.0.0",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "lefthook": "^2.1.6",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "lint:report": "biome lint --reporter=json --log-level=none > biome_report.json",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "check": "biome check --write",
    "check:ci": "biome check",
    "ci": "biome ci"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "@cloudflare/workers-types"
      ]
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "@swc/core",
      "better-sqlite3",
      "esbuild",
      "lefthook",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver",
      "workerd"
    ],
    "overrides": {
      "bitflag-js": "1.1.0",
      "undici@<5.8.0": ">=5.8.0",
      "undici@<=5.8.1": ">=5.8.2",
      "undici@<5.19.1": ">=5.19.1",
      "undici@>=2.0.0 <5.19.1": ">=5.19.1",
      "undici@<5.26.2": ">=5.26.2",
      "undici@<5.28.4": ">=5.28.4",
      "undici@<=5.28.2": ">=8.2.0",
      "undici@>=4.5.0 <5.28.5": ">=5.28.5",
      "esbuild@<=0.24.2": ">=0.25.0",
      "undici@<5.29.0": ">=5.29.0"
    },
    "patchedDependencies": {
      "slash-up": "patches/slash-up.patch"
    }
  }
}
